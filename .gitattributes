# Normalize line endings: store and check out all text files with LF.
# This prevents spurious "modified" status caused by CRLF/LF mismatch
# (e.g. core.autocrlf=true on Windows expecting CRLF while files are LF).
* text=auto eol=lf

# Explicit rules for source files in this project
*.c   text eol=lf
*.h   text eol=lf
*.sh  text eol=lf
*.md  text eol=lf
*.txt text eol=lf
